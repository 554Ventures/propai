{
  "name": "@propai/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo 'api lint not initialized'",
    "type-check": "tsc --noEmit",
    "test": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed && dotenv -e .env.test -- prisma generate && dotenv -e .env.test -- vitest run",
    "test:integration": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed && dotenv -e .env.test -- prisma generate && dotenv -e .env.test -- vitest run src/__tests__/ai-chat.integration.test.ts",
    "prisma": "prisma",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "1.4.5-lts.2",
    "openai": "^4.91.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "bcrypt": "^6.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
