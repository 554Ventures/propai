generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  FAILED
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ServiceCategory {
  HVAC
  PLUMBING
  ELECTRICAL
  PEST_CONTROL
  CLEANING
  LANDSCAPING
  GENERAL_REPAIR
  PAINTING
  ROOFING
  SECURITY
}

enum DocumentType {
  LEASE
  RECEIPT
  INSPECTION
  INSURANCE
  TAX
  OTHER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PlaidConnectionStatus {
  ACTIVE
  DISCONNECTED
  ERROR
  REAUTH_REQUIRED
}

enum PlaidImportedTransactionStatus {
  AUTO_APPROVED
  NEEDS_REVIEW
  REVIEWED
  EXCLUDED
  REMOVED
  SYNC_ERROR
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  memberships Membership[]

  properties    Property[]
  units         Unit[]
  tenants       Tenant[]
  leases        Lease[]
  payments      Payment[]
  maintenance   MaintenanceRequest[]
  vendors       Vendor[]
  expenses      Expense[]
  transactions  Transaction[]
  plaidItems    PlaidItem[]
  plaidAccounts PlaidAccount[]
  plaidImportedTransactions PlaidImportedTransaction[]
  documents     Document[]
  notifications Notification[]
  aiInsights    AIInsight[]
  chatSessions  ChatSession[]

  aiUsage          AiUsage[]
  aiSecurityEvents AiSecurityEvent[]
  aiBudget         AiBudget[]

  aiActionLogs       AiActionLog[]
  aiActionExecutions AiActionExecution[]

  invitations Invitation[]
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  // One org per user for now (org switching later)
  @@unique([userId])
  @@index([organizationId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  defaultOrgId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [defaultOrgId], references: [id], onDelete: Cascade)
  memberships  Membership[]

  properties    Property[]
  units         Unit[]
  tenants       Tenant[]
  leases        Lease[]
  payments      Payment[]
  maintenance   MaintenanceRequest[]
  vendors       Vendor[]
  expenses      Expense[]
  transactions  Transaction[]
  plaidItems     PlaidItem[]
  plaidAccounts  PlaidAccount[]
  plaidImportedTransactions PlaidImportedTransaction[]
  documents     Document[]
  notifications Notification[]
  aiInsights    AIInsight[]

  aiActionLogs       AiActionLog[]
  aiActionExecutions AiActionExecution[]
  chatSessions       ChatSession[]
  aiUsage            AiUsage[]
  aiSecurityEvents   AiSecurityEvent[]
  aiBudget           AiBudget?

  sentInvitations Invitation[] @relation("InvitedBy")

  @@index([defaultOrgId])
}

model Invitation {
  id              String    @id @default(cuid())
  organizationId  String
  email           String
  role            OrgRole   @default(MEMBER)
  tokenHash       String    @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  invitedByUserId String
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([tokenHash])
}

model Property {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  name           String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  postalCode     String
  country        String    @default("US")
  notes          String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])
  units        Unit[]
  leases       Lease[]
  payments     Payment[]
  maintenance  MaintenanceRequest[]
  expenses     Expense[]
  transactions Transaction[]
  plaidImportedTransactions PlaidImportedTransaction[]
  documents    Document[]
  aiInsights   AIInsight[]
  chatSessions ChatSession[]

  @@index([organizationId])
}

model Unit {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String
  label          String
  bedrooms       Int?
  bathrooms      Float?
  squareFeet     Int?
  rent           Int?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])
  property     Property             @relation(fields: [propertyId], references: [id])
  leases       Lease[]
  maintenance  MaintenanceRequest[]

  @@index([organizationId])
}

model Tenant {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])
  leases       Lease[]
  maintenance  MaintenanceRequest[]

  @@index([organizationId])
}

model Lease {
  id             String      @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String
  unitId         String
  tenantId       String
  startDate      DateTime
  endDate        DateTime?
  rent           Int
  status         LeaseStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  payments     Payment[]
  documents    Document[]

  @@index([organizationId])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String
  leaseId        String
  amount         Int
  dueDate        DateTime
  paidDate       DateTime?
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  lease        Lease        @relation(fields: [leaseId], references: [id])

  @@index([organizationId])
}

model MaintenanceRequest {
  id             String            @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String
  unitId         String?
  tenantId       String?
  vendorId       String?
  title          String
  description    String?
  status         MaintenanceStatus @default(PENDING)
  cost           Int?
  vendorAssignedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([vendorId])
}

model Vendor {
  id               String            @id @default(cuid())
  userId           String
  organizationId   String
  name             String
  email            String?
  phone            String?
  serviceCategories ServiceCategory[]
  trade            String?  // Legacy field, prefer serviceCategories
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user                User                   @relation(fields: [userId], references: [id])
  organization        Organization           @relation(fields: [organizationId], references: [id])
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]

  @@index([organizationId])
  @@index([serviceCategories])
}

model Expense {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String
  vendorId       String?
  amount         Int
  category       String
  date           DateTime
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  aiInsights   AIInsight[]

  @@index([organizationId])
}

model Transaction {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  type           TransactionType
  amount         Decimal         @db.Decimal(12, 2)
  date           DateTime
  category       String
  propertyId     String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  plaidImportedTransaction PlaidImportedTransaction?

  @@index([organizationId])
  @@index([organizationId, date])
  @@index([organizationId, propertyId])
  @@index([organizationId, type])
}

model PlaidItem {
  id                  String                @id @default(cuid())
  organizationId      String
  userId              String
  plaidItemId         String
  institutionId       String?
  institutionName     String?
  encryptedAccessToken String
  syncCursor          String?
  status              PlaidConnectionStatus @default(ACTIVE)
  lastSyncedAt        DateTime?
  lastSyncError       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts     PlaidAccount[]
  transactions PlaidImportedTransaction[]

  @@unique([organizationId, plaidItemId])
  @@index([organizationId])
  @@index([organizationId, status])
}

model PlaidAccount {
  id             String                @id @default(cuid())
  organizationId String
  userId         String
  plaidItemId    String
  plaidAccountId String
  name           String
  mask           String?
  type           String?
  subtype        String?
  status         PlaidConnectionStatus @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         PlaidItem    @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  transactions PlaidImportedTransaction[]

  @@unique([organizationId, plaidAccountId])
  @@index([organizationId])
  @@index([plaidItemId])
}

model PlaidImportedTransaction {
  id                  String                         @id @default(cuid())
  organizationId      String
  userId              String
  plaidItemId         String
  accountId           String
  plaidTransactionId  String
  transactionId       String?                        @unique
  propertyId          String?
  name                String
  merchantName        String?
  amount              Decimal                        @db.Decimal(12, 2)
  date                DateTime
  authorizedDate      DateTime?
  isoCurrencyCode     String?
  plaidCategory       String?
  suggestedType       TransactionType
  suggestedCategory   String?
  categoryConfidence  Float?
  propertyConfidence  Float?
  reviewStatus        PlaidImportedTransactionStatus @default(NEEDS_REVIEW)
  reviewReason        String?
  reviewedAt          DateTime?
  raw                 Json?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         PlaidItem    @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  account      PlaidAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@unique([organizationId, plaidTransactionId])
  @@index([organizationId])
  @@index([organizationId, reviewStatus])
  @@index([organizationId, date])
  @@index([organizationId, propertyId])
}

model AIInsight {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String?
  expenseId      String?
  type           String
  input          Json
  output         Json
  confidence     Float?
  reasoning      String?
  overrideValue  String?
  overriddenAt   DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  expense      Expense?     @relation(fields: [expenseId], references: [id])

  @@index([organizationId])
}

model Document {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String?
  leaseId        String?
  type           DocumentType
  name           String
  url            String
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  lease        Lease?       @relation(fields: [leaseId], references: [id])

  @@index([organizationId])
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  type           String
  message        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ChatSession {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  propertyId     String?
  title          String?
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  property     Property?     @relation(fields: [propertyId], references: [id])
  messages     ChatMessage[]

  @@index([organizationId])
  @@index([organizationId, userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session   ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolCalls ToolCallLog[]

  @@index([sessionId, createdAt])
}

model ToolCallLog {
  id        String   @id @default(cuid())
  messageId String
  toolName  String
  inputs    Json
  outputs   Json?
  status    String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AiUsage {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  sessionId      String?
  messageId      String?
  model          String
  inputTokens    Int
  outputTokens   Int
  totalTokens    Int
  costUsd        Float?
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AiSecurityEvent {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String?
  sessionId      String?
  type           String
  severity       String
  message        String
  metadata       Json?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AiBudget {
  id              String   @id @default(cuid())
  userId          String   @unique
  organizationId  String
  monthlyLimitUsd Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AiActionLog {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  actionType     String
  payload        Json
  status         String
  result         Json?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AiActionExecution[]

  @@index([organizationId])
  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([organizationId, actionType])
}

model AiActionExecution {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  actionId        String
  clientRequestId String
  status          String   @default("CONFIRMED")
  result          Json?
  error           String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       AiActionLog  @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([actionId, clientRequestId])
  @@index([organizationId])
  @@index([organizationId, userId])
}
